<div class="row g-4">
  {% for service in services %}
    <div class="col-md-4">
      <div class="card h-100">
        <div class="card-content text-start p-3">
          
          <!-- Icon SVG -->
          {% if service.icon_svg %}
            <div class="mb-3">
              {{ service.icon_svg|safe }}
            </div>
          {% endif %}

          <!-- Title -->
          <h5 class="h5-small-title">{{ service.title }}</h5>

          <!-- Description -->
          <p class="body text-muted">{{ service.description }}</p>

        </div>
      </div>
    </div>
  {% endfor %}
</div>
</section>


